function cCascadeGer() {
  const reg = document.getElementById('cFiltReg').value;
  const ger = document.getElementById('cFiltGer').value;
  const pdv = document.getElementById('cFiltPDV');
  pdv.innerHTML='<option value="">Todas las tiendas</option>';
