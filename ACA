// ─── ROTACIÓN ────────────────────────────────────────────────────────────────
function renderRotacion() {
  const ohReg=D.oh_reg||[];
  const avgM=D.cat_avg_monthly_2026||{};
  const cats=['Cables','Cases iPhone','Charger','Liquid','Micas','Accesories'];
  const shortCats={'Cables':'Cables','Cases iPhone':'Cases','Charger':'Charger','Liquid':'Liquid','Micas':'Micas','Accesories':'Acc.'};
  const semanas=(oh,cat)=>avgM[cat]?+(oh/(avgM[cat]/4.3)).toFixed(1):null;
  const semColor=s=>s===null?'#ccc':s<=12?'#00A651':s<=24?'#E5A000':'#E8001D';
  const semEmoji=s=>s===null?'—':s<=12?'🟢':s<=24?'🟡':'🔴';
  // Global cat KPIs
  const ohCats=D.oh_cats||[];
  const kpiRot=cats.map(cat=>{
    const ohU=ohCats.find(c=>c.c===cat)?.u||0;
    const sem=semanas(ohU,cat);
    return {cat,ohU,sem};
  });
  document.getElementById('kpiGridRot').innerHTML=kpiRot.map(k=>`
    <div class="kpi-card">
      <div class="kpi-label">${k.cat}</div>
      <div class="kpi-value" style="font-size:20px;color:${semColor(k.sem)}">${k.sem??'—'} sem</div>
      <div class="kpi-sub">OH: ${fmt(k.ohU)} uds</div>
    </div>
  `).join('');
  // Bar chart semanas por cat
  if(_charts.rotCat) _charts.rotCat.destroy();
  _charts.rotCat=new Chart(document.getElementById('chartRotCat').getContext('2d'),{
    type:'bar',
    data:{labels:cats.map(c=>shortCats[c]),datasets:[{
      label:'Semanas de inventario',
      data:kpiRot.map(k=>k.sem),
      backgroundColor:kpiRot.map(k=>semColor(k.sem)),
      borderRadius:6
    }]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},
      tooltip:{callbacks:{label:ctx=>` ${ctx.raw} semanas`}},
      annotation:{annotations:{line1:{type:'line',yMin:12,yMax:12,borderColor:'#00A651',borderWidth:1.5,borderDash:[4,4]},line2:{type:'line',yMin:24,yMax:24,borderColor:'#E8001D',borderWidth:1.5,borderDash:[4,4]}}}},
      scales:{x:{grid:{display:false}},y:{grid:{color:'#EEF0F5'}}}}
  });
  // Scatter OH vs ventas
  if(_charts.ohVentas) _charts.ohVentas.destroy();
  _charts.ohVentas=new Chart(document.getElementById('chartOHvsVentas').getContext('2d'),{
    type:'scatter',
    data:{datasets:[{
      label:'Categoría',
      data:kpiRot.map(k=>({x:avgM[k.cat]||0,y:k.ohU,label:k.cat})),
      backgroundColor:CAT_COLORS,
      pointRadius:10,pointHoverRadius:13
    },{
      label:'OH = 2 meses',
      data:[{x:0,y:0},{x:Math.max(...Object.values(avgM)),y:Math.max(...Object.values(avgM))*2}],
      type:'line',borderColor:'rgba(100,100,100,.4)',borderDash:[4,4],pointRadius:0,showLine:true
    }]},
    options:{responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>{
        const d=ctx.raw;
        return `${d.label}: OH=${fmt(d.y)} vs Avg=${fmt(d.x)}/mes`;
      }}}},
      scales:{x:{title:{display:true,text:'Venta promedio mensual (uds)'},ticks:{callback:v=>fmt(v)}},
        y:{title:{display:true,text:'OH (uds)'},ticks:{callback:v=>fmt(v)}}}}
  });
  // Semáforo región x cat
  document.getElementById('tbodySemaforo').innerHTML=ohReg.map(r=>`<tr>
    <td><strong>${r.r}</strong></td>
    ${cats.map(cat=>{
      const oh=r[cat]||0;
      const s=semanas(oh,cat);
      return `<td style="text-align:center;background:${s===null?'#f9f9f9':s<=12?'rgba(0,166,81,.12)':s<=24?'rgba(229,160,0,.12)':'rgba(232,0,29,.12)'}">
        <div style="font-size:13px">${semEmoji(s)}</div>
        <div style="font-size:10px;font-weight:700;color:${semColor(s)}">${s??'—'}</div>
      </td>`;
    }).join('')}
  </tr>`).join('');
}

// ─── EXPORT ──────────────────────────────────────────────────────────────────
function toggleMenu(btn) {
  const menu=btn.nextElementSibling;
  document.querySelectorAll('.export-menu.open').forEach(m=>{if(m!==menu) m.classList.remove('open');});
  menu.classList.toggle('open');
  document.addEventListener('click',function h(e){if(!btn.parentElement.contains(e.target)){menu.classList.remove('open');document.removeEventListener('click',h);}},{once:true});
}
function exportImg(btn) {
  const section=btn.closest('.section');
  html2canvas(section,{scale:2,backgroundColor:'#F4F6FA'}).then(canvas=>{
    const a=document.createElement('a');a.download='dashboard.png';a.href=canvas.toDataURL();a.click();
  });
  btn.closest('.export-menu').classList.remove('open');
}
function exportXls(btn) {
  const section=btn.closest('.section');
  const tables=section.querySelectorAll('table');
  if(!tables.length){alert('No hay tabla en esta sección.');return;}
  const wb=XLSX.utils.book_new();
  tables.forEach((tbl,i)=>{
    const ws=XLSX.utils.table_to_sheet(tbl);
    XLSX.utils.book_append_sheet(wb,ws,`Tabla${i+1}`);
  });
  XLSX.writeFile(wb,'dashboard_export.xlsx');
  btn.closest('.export-menu').classList.remove('open');
}
</script>
