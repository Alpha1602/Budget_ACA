  });
  renderCuota();
}
function cReset() {
  ['cFiltReg','cFiltGer','cFiltPDV'].forEach(id=>{
    const el=document.getElementById(id);
    el.innerHTML=el.options[0].outerHTML;
  });
  cCascadeReg();
}
function renderCuota() {
  const stores = cuotaStoresFiltered();
  const reg = document.getElementById('cFiltReg').value;

  // KPIs
  const totCuota = stores.reduce((a,s)=>a+s.cuota,0);
  const totVenta = stores.reduce((a,s)=>a+s.venta,0);
  const totOH    = stores.reduce((a,s)=>a+s.oh,0);
  const totRes   = stores.reduce((a,s)=>a+s.resurtido,0);
  const alcance  = totCuota ? (totVenta/totCuota*100).toFixed(1) : '—';
  const disponible = totOH + totRes;
  const alcDisp  = totCuota ? Math.min((disponible/totCuota)*100,100).toFixed(0) : '—';

  document.getElementById('cuotaKPIs').innerHTML = `
    <div class="kpi-card"><div class="kpi-label">Cuota Jul</div><div class="kpi-value">${fmt(totCuota)}</div><div class="kpi-sub">${stores.length} tiendas</div></div>
    <div class="kpi-card"><div class="kpi-label">Venta Jul</div><div class="kpi-value" style="color:var(--blue)">${fmt(totVenta)}</div><div class="kpi-sub" id="alcSub">${alcance}% de cuota</div></div>
    <div class="kpi-card"><div class="kpi-label">OH + Resurtido</div><div class="kpi-value" style="font-size:18px">${fmt(disponible)}</div><div class="kpi-sub">${alcDisp}% cubre cuota</div></div>
    <div class="kpi-card"><div class="kpi-label">Inventario OH</div><div class="kpi-value" style="font-size:20px">${fmt(totOH)}</div><div class="kpi-sub">Resurtido: ${fmt(totRes)}</div></div>
  `;

  // Chart: alcance por región (o por gerente si hay filtro de región)
  const chartBy = !reg ? 'region' : 'gerente';
  const groups = {};
  stores.forEach(s=>{
    const key = s[chartBy]||'—';
    if(!groups[key]) groups[key]={cuota:0,venta:0};
    groups[key].cuota+=s.cuota;
    groups[key].venta+=s.venta;
  });
  const gKeys = Object.keys(groups).sort();
  const gAlcance = gKeys.map(k=>groups[k].cuota ? +(groups[k].venta/groups[k].cuota*100).toFixed(1) : 0);
  document.getElementById('cuotaChartTitle').textContent = !reg ? '% Alcance por Región — Julio' : `% Alcance por Regional — ${reg}`;
  if(_cuotaChart) _cuotaChart.destroy();
  _cuotaChart = new Chart(document.getElementById('chartCuota').getContext('2d'),{
    type:'bar',
    data:{labels:gKeys.map(k=>k.length>25?k.substring(0,22)+'…':k),datasets:[{
      label:'Alcance %',
      data:gAlcance,
      backgroundColor:gAlcance.map(v=>v>=100?'rgba(0,166,81,.85)':v>=60?'rgba(245,166,35,.85)':'rgba(232,0,29,.8)'),
      borderRadius:6
    }]},
    options:{responsive:true,maintainAspectRatio:false,indexAxis:'y',
      plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>` ${ctx.raw}% de cuota`}}},
      scales:{x:{max:120,ticks:{callback:v=>v+'%'},grid:{color:'#EEF0F5'}},y:{grid:{display:false},ticks:{font:{size:10}}}}
    }
  });

  // Table
  document.getElementById('tbodyCuota').innerHTML = stores.map((s,i)=>{
    const disp = s.oh+s.resurtido;
    const alc  = s.cuota ? (s.venta/s.cuota*100).toFixed(1) : '0.0';
    const rColor = s.riesgo==='Riesgo alto'?'red':s.riesgo==='Riesgo medio'?'neutral':'pos';
    return `<tr>
      <td style="color:var(--text-muted);font-size:11px">${i+1}</td>
      <td><div style="font-weight:600;font-size:12px;line-height:1.3">${s.nombre.replace(/^PRM TDA /,'').replace(/^PRM /,'')}</div><div style="font-size:11px;color:var(--text-muted)">${s.gerente||s.region}</div></td>
      <td style="text-align:right">${fmt(s.cuota)}</td>
      <td style="text-align:right"><strong>${fmt(s.venta)}</strong></td>
      <td style="text-align:right">${fmt(s.oh)}</td>
      <td style="text-align:right">${fmt(s.resurtido)}</td>
      <td style="text-align:right">${fmt(disp)}</td>
      <td style="text-align:right">${badge(alc==='0.0'?'—':alc.replace('.0','').replace('-',''))}</td>
      <td style="text-align:center"><span class="badge ${rColor}" style="font-size:10px">${s.riesgo||'—'}</span></td>
    </tr>`;
  }).join('');
}

