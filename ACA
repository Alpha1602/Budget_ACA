<script>
// ─── CONSTANTES ───────────────────────────────────────────────────────────────
const MES = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const REGIONES_ORDER = ['BAJIO-NORTE 2','CENTRO','NOROESTE','NORTE 1','PACIFICO','SUR PENINSULA'];
const REG_COLORS = {'BAJIO-NORTE 2':'#0057B8','CENTRO':'#00A651','NOROESTE':'#F5A623','NORTE 1':'#E8001D','PACIFICO':'#7B2FBE','SUR PENINSULA':'#00B4D8'};
const CAT_COLORS = ['#0057B8','#00A651','#F5A623','#E8001D','#7B2FBE','#00B4D8'];

// ─── HELPERS ─────────────────────────────────────────────────────────────────
const fmt  = n  => (n||n===0) ? Math.round(n).toLocaleString('es-MX') : '—';
const pct  = (a,b) => b ? (((b-a)/a)*100).toFixed(1) : '—';
const fmtP = v  => v !== '—' ? (parseFloat(v) >= 0 ? `+${v}%` : `${v}%`) : '—';
const badge = v => {
  if(v==='—') return `<span class="badge neutral">—</span>`;
  const n = parseFloat(v);
  return `<span class="badge ${n>=0?'pos':'neg'}">${n>=0?'▲':'▼'} ${Math.abs(n).toFixed(1)}%</span>`;
};
const pctStr = (a,b) => b ? ((a/b)*100).toFixed(1)+'%' : '—';

// ─── GLOBAL DATA ─────────────────────────────────────────────────────────────
let D = null;   // data.json payload
let _charts = {};

// ─── LOAD DATA ───────────────────────────────────────────────────────────────
// data.js se carga como <script> en el <head>, lo que funciona tanto con
// file:// (local) como con GitHub Pages (servidor). Asigna window.DASHBOARD_DATA.
(function() {
  if (window.DASHBOARD_DATA) {
    D = window.DASHBOARD_DATA;
    document.getElementById('loading').style.display = 'none';
    document.querySelector('#resumen').classList.remove('active');
    document.querySelector('#cuota').classList.add('active');
    init();
  } else {
    document.getElementById('loading').textContent =
      '❌ No se encontró data.js. Ejecuta extract_data.py primero y asegúrate de que data.js esté en la misma carpeta que index.html.';
  }
})();

function init() {
  // Header badge
  document.getElementById('headerBadge').textContent = `📊 Dashboard actualizado · Datos al ${D.fecha}`;
  document.getElementById('arFecha').textContent = D.fecha;

  // Populate region selects
  const regSelects = ['selectRegCat','selectRegOHDetalle','selectRegOH','lcSelReg'];
  regSelects.forEach(id => {
    const sel = document.getElementById(id);
    if(!sel) return;
    REGIONES_ORDER.forEach(r => {
      const op = document.createElement('option'); op.value = r; op.textContent = r;
      sel.appendChild(op);
    });
  });

  // Build cuota filters
  const regs = [...new Set(D.cuota_stores.map(s=>s.region))].sort();
  regs.forEach(r => {
    const op = document.createElement('option'); op.value = r; op.textContent = r;
    document.getElementById('cFiltReg').appendChild(op);
  });
  // AR filters
  const arRegs = [...new Set(D.ar_stores.map(s=>s.region).filter(r=>!r.startsWith('TOTAL')))].sort();
  arRegs.forEach(r => {
    const op = document.createElement('option'); op.value = r; op.textContent = r;
    document.getElementById('arSelReg').appendChild(op);
  });
  // LC selects
  REGIONES_ORDER.forEach(r => {
    const op = document.createElement('option'); op.value = r; op.textContent = r;
    document.getElementById('lcSelReg').appendChild(op);
  });

  renderResumen();
  renderCuota();
  renderOH();
  renderAR();
  renderLC();
  renderCategorias();
  renderRegiones();
  renderRotacion();
}

// ─── TAB NAVIGATION ──────────────────────────────────────────────────────────
function showTab(id, el) {
  document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  el.classList.add('active');
}

// ─── RESUMEN ─────────────────────────────────────────────────────────────────
function renderResumen() {
  const k = D.kpis;
  document.getElementById('kRes26').textContent = fmt(k.uds_2026_cmp);
  document.getElementById('kRes25').textContent = fmt(k.uds_2025_cmp);
  const g = ((k.uds_2026_cmp - k.uds_2025_cmp)/k.uds_2025_cmp*100).toFixed(1);
  const gEl = document.getElementById('kResGrowth');
  gEl.textContent = fmtP(g);
  gEl.className = `kpi-value ${parseFloat(g)>=0?'pos':'neg'}`;
  const gb = document.getElementById('kResGrowthBadge');
  gb.textContent = parseFloat(g)>=0 ? `▲ ${g}% vs 2025` : `▼ ${g}% vs 2025`;
  gb.className = `kpi-badge ${parseFloat(g)>=0?'pos':'neg'}`;
  document.getElementById('kResRegs').textContent = k.num_regiones_cmp;
  document.getElementById('kResRegsSub').textContent = `${k.num_gerentes_cmp} gerentes`;
  document.getElementById('kResTotal25').textContent = fmt(k.uds_2025);
  document.getElementById('kResTotal26').textContent = fmt(k.uds_2026);
  document.getElementById('kResTotalPer').textContent = fmt(k.total_uds);

  // Monthly chart
  const m25 = D.monthly['2025'] || [];
  const m26 = D.monthly['2026'] || [];
  const yoyPct = MES.map((_, i) => {
    const v25=m25[i], v26=m26[i];
    if(!v25||!v26) return null;
    return +((v26-v25)/v25*100).toFixed(1);
  });
  const bar26Colors = MES.map((_,i)=>{
    const p=yoyPct[i];
    if(p===null) return 'rgba(180,180,180,.5)';
    return p>=0?'rgba(0,166,81,.85)':'rgba(232,0,29,.8)';
  });
  if(_charts.monthly) _charts.monthly.destroy();
  _charts.monthly = new Chart(document.getElementById('chartMonthly').getContext('2d'),{
    type:'bar',
    data:{labels:MES,datasets:[
      {label:'2025',data:m25,backgroundColor:'rgba(0,87,184,.75)',borderRadius:4},
      {label:'2026',data:m26,backgroundColor:bar26Colors,borderRadius:4}
    ]},
    options:{responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>{
        const b=` ${ctx.dataset.label}: ${ctx.raw?fmt(ctx.raw):'—'} uds`;
        if(ctx.datasetIndex===1&&yoyPct[ctx.dataIndex]!==null){
          const p=yoyPct[ctx.dataIndex];
          return b+`  (${p>=0?'▲ +':'▼ '}${p}% vs 2025)`;
        }
        return b;
      }}}},
      scales:{x:{grid:{display:false}},y:{grid:{color:'#EEF0F5'},ticks:{callback:v=>v>=1000?(v/1000).toFixed(0)+'k':v}}}
    },
    plugins:[{id:'yoyLabels',afterDatasetsDraw(chart){
      const {ctx:c,scales:{x,y}}=chart;
      const ds1=chart.getDatasetMeta(1);
      c.save();
      ds1.data.forEach((bar,i)=>{
        const p=yoyPct[i];
        if(p===null) return;
        c.fillStyle=p>=0?'#00A651':'#E8001D';
        c.font='bold 9px -apple-system,sans-serif';
        c.textAlign='center';c.textBaseline='bottom';
        c.fillText((p>=0?'+':'')+p+'%',bar.x,bar.y-2);
      });
      c.restore();
    }}]
  });

  // Cat pie
  const cats = D.cats||[];
  const total26 = cats.reduce((a,c)=>a+c.u26,0);
  if(_charts.catPie) _charts.catPie.destroy();
  _charts.catPie = new Chart(document.getElementById('chartCatPie').getContext('2d'),{
    type:'doughnut',
    data:{labels:cats.map(c=>c.c),datasets:[{data:cats.map(c=>c.u26),backgroundColor:CAT_COLORS,borderWidth:2,borderColor:'#fff'}]},
    options:{responsive:true,maintainAspectRatio:false,
      plugins:{legend:{position:'right',labels:{font:{size:12},boxWidth:12,padding:12}},
        tooltip:{callbacks:{label:ctx=>` ${ctx.label}: ${fmt(ctx.raw)} (${(ctx.raw/total26*100).toFixed(1)}%)`}}},
      cutout:'60%'}
  });
}

// ─── REGIONES ────────────────────────────────────────────────────────────────
function renderRegiones() {
  const regs = D.regiones||[];
  const total26 = regs.reduce((a,r)=>a+r.u26,0);
  const maxU26  = Math.max(...regs.map(r=>r.u26));
  document.getElementById('tbodyRegiones').innerHTML = regs.map(r=>{
    const g = pct(r.u25,r.u26);
    const share = (r.u26/total26*100).toFixed(1);
    const bw = (r.u26/maxU26*100).toFixed(0);
    const n = parseFloat(g);
    return `<tr>
      <td><strong>${r.r}</strong></td>
      <td style="text-align:right">${fmt(r.u25)}</td>
      <td style="text-align:right"><strong>${fmt(r.u26)}</strong></td>
      <td style="text-align:right">${badge(g)}</td>
      <td style="min-width:80px"><div style="font-size:11px;color:var(--text-muted)">${share}%</div><div class="bar-wrap"><div class="bar-fill ${n>=0?'green':'red'}" style="width:${bw}%"></div></div></td>
    </tr>`;
  }).join('');

  if(_charts.regiones) _charts.regiones.destroy();
  _charts.regiones = new Chart(document.getElementById('chartRegiones').getContext('2d'),{
    type:'bar',
    data:{labels:regs.map(r=>r.r.replace('BAJIO-NORTE 2','B-N2').replace('SUR PENINSULA','SUR PEN')),
      datasets:[
        {label:'2025',data:regs.map(r=>r.u25),backgroundColor:'rgba(0,87,184,.7)',borderRadius:4},
        {label:'2026',data:regs.map(r=>r.u26),backgroundColor:'rgba(0,166,81,.8)',borderRadius:4}
      ]},
    options:{responsive:true,maintainAspectRatio:false,
      plugins:{legend:{labels:{font:{size:12},boxWidth:12}}},
      scales:{x:{grid:{display:false}},y:{grid:{color:'#EEF0F5'},ticks:{callback:v=>v>=1000?(v/1000).toFixed(0)+'k':v}}}
    }
  });
}

// ─── CATEGORÍAS ──────────────────────────────────────────────────────────────
function renderCategorias() {
  const reg = document.getElementById('selectRegCat')?.value||'';
  const data = (reg && D.cats_reg && D.cats_reg[reg]) ? D.cats_reg[reg] : D.cats||[];
  const sorted = [...data].sort((a,b)=>b.u26-a.u26);
  const total26 = sorted.reduce((a,c)=>a+c.u26,0);
  const max26   = sorted[0]?.u26||1;
  document.getElementById('tbodyCat').innerHTML = sorted.map(c=>{
    const share = (c.u26/total26*100).toFixed(1);
    return `<tr><td><strong>${c.c}</strong></td><td style="text-align:right">${fmt(c.u25)}</td><td style="text-align:right">${fmt(c.u26)}</td><td style="text-align:right">${fmt(c.u25+c.u26)}</td>
      <td style="min-width:80px"><div style="font-size:11px;color:var(--text-muted)">${share}%</div><div class="bar-wrap"><div class="bar-fill" style="width:${(c.u26/max26*100).toFixed(0)}%"></div></div></td></tr>`;
  }).join('');
  if(_charts.catBar) _charts.catBar.destroy();
  _charts.catBar = new Chart(document.getElementById('chartCatBar').getContext('2d'),{
    type:'bar',
    data:{labels:sorted.map(c=>c.c),datasets:[
      {label:'2025',data:sorted.map(c=>c.u25),backgroundColor:'rgba(0,87,184,.75)',borderRadius:4},
      {label:'2026 YTD',data:sorted.map(c=>c.u26),backgroundColor:'rgba(0,166,81,.85)',borderRadius:4}
    ]},
    options:{responsive:true,maintainAspectRatio:false,
      plugins:{legend:{labels:{font:{size:12},boxWidth:12}}},
      scales:{x:{grid:{display:false}},y:{grid:{color:'#EEF0F5'},ticks:{callback:v=>v>=1000?(v/1000).toFixed(0)+'k':v}}}
    }
  });
}

// ─── OH ──────────────────────────────────────────────────────────────────────
function renderOH() {
  const ohCats = D.oh_cats||[];
  const ohTotal = D.oh_total||0;
  document.getElementById('kOHTotal').textContent = fmt(ohTotal);
  const labels3 = ['Cables','Cases iPhone','Charger'];
  const kIds = [['kOHCat1Label','kOHCat1','kOHCat1Pct'],['kOHCat2Label','kOHCat2','kOHCat2Pct'],['kOHCat3Label','kOHCat3','kOHCat3Pct']];
  labels3.forEach((cat,i)=>{
    const entry = ohCats.find(c=>c.c===cat)||{u:0};
    document.getElementById(kIds[i][0]).textContent = cat;
    document.getElementById(kIds[i][1]).textContent = fmt(entry.u);
    document.getElementById(kIds[i][2]).textContent = `${(entry.u/ohTotal*100).toFixed(1)}% del OH`;
  });
  if(_charts.ohCat) _charts.ohCat.destroy();
  _charts.ohCat = new Chart(document.getElementById('chartOHCat').getContext('2d'),{
    type:'bar',
    data:{labels:ohCats.map(c=>c.c),datasets:[{label:'Unidades OH',data:ohCats.map(c=>c.u),backgroundColor:CAT_COLORS,borderRadius:6}]},
    options:{responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>` ${fmt(ctx.raw)} uds (${(ctx.raw/ohTotal*100).toFixed(1)}%)`}}},
      scales:{x:{grid:{display:false}},y:{grid:{color:'#EEF0F5'},ticks:{callback:v=>v>=1000?(v/1000).toFixed(0)+'k':v}}}
    }
  });
  renderOHRegDetalle();
  renderOHModelos();
  renderOHPDV();
}

function renderOHRegDetalle() {
  const reg = document.getElementById('selectRegOHDetalle').value;
  const thead = document.getElementById('theadOHReg');
  const tbody = document.getElementById('tbodyOHReg');
  document.getElementById('ohRegTitle').textContent = reg ? `OH por Tienda — ${reg}` : 'OH por Región y Categoría';
  document.getElementById('ohRegSubtitle').textContent = reg ? 'Detalle por tienda' : 'Selecciona una región para ver detalle por tienda';
  if(!reg) {
