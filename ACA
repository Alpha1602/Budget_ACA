"""
extract_data.py
Genera data.json leyendo el archivo "Sales YoY .xlsx" (o el nombre
que se le pase como argumento).  Ejecutar con:
    python extract_data.py
    python extract_data.py "mi_archivo.xlsx"
"""

import sys
import json
import datetime
from collections import defaultdict
from pathlib import Path

try:
    import openpyxl
except ImportError:
    print("Instalando openpyxl...")
    import subprocess
    subprocess.run([sys.executable, "-m", "pip", "install", "openpyxl", "--break-system-packages", "-q"])
    import openpyxl

# ── Helpers ──────────────────────────────────────────────────────────────────
def safe_int(v):
    try:
        return int(float(v)) if v is not None and v != '-' else 0
    except Exception:
        return 0

def safe_float(v):
    try:
        return float(v) if v is not None and v != '-' else 0.0
    except Exception:
        return 0.0

XLSX_PATH = sys.argv[1] if len(sys.argv) > 1 else "Sales YoY .xlsx"
print(f"Leyendo: {XLSX_PATH}")

wb = openpyxl.load_workbook(XLSX_PATH, read_only=True, data_only=True)

data = {}

# ─────────────────────────────────────────────────────────────────────────────
# 1. DASHBOARD — KPIs globales + tendencia mensual + regiones + categorías
# ─────────────────────────────────────────────────────────────────────────────
ws_dash = wb['Dashboard']
rows_dash = list(ws_dash.iter_rows(values_only=True))

# Fila 3 (índice 3): KPIs acumulados y comparables
kpi_row = rows_dash[3]
data['kpis'] = {
    'total_uds':    safe_int(kpi_row[0]),
    'uds_2025':     safe_int(kpi_row[1]),
    'uds_2026':     safe_int(kpi_row[2]),
    'crecimiento_total': safe_float(kpi_row[3]),
    'num_regiones': safe_int(kpi_row[4]),
    'num_gerentes': safe_int(kpi_row[5]),
    # Comparable Ene-Jul
    'total_comparable':  safe_int(kpi_row[7]),
    'uds_2025_cmp':      safe_int(kpi_row[8]),
    'uds_2026_cmp':      safe_int(kpi_row[9]),
    'crecimiento_cmp':   safe_float(kpi_row[10]),
    'num_regiones_cmp':  safe_int(kpi_row[11]),
    'num_gerentes_cmp':  safe_int(kpi_row[12]),
}

# Tendencia mensual (filas 17-18)
data['monthly'] = {}
for row in rows_dash[16:21]:
    year = row[0]
    if year in (2025, 2026):
        vals = [safe_int(row[i]) if row[i] else None for i in range(1, 13)]
        # Convertir 0 → None para meses sin dato en 2026
        if year == 2026:
            vals = [v if (v and v > 0) else None for v in vals]
        data['monthly'][str(year)] = vals

# Regiones (filas 7-12)
REGIONES_ORDER = ['BAJIO-NORTE 2','CENTRO','NOROESTE','NORTE 1','PACIFICO','SUR PENINSULA']
data['regiones'] = []
for row in rows_dash[6:14]:
    if row[0] and row[0] not in ('Región','Total general') and row[0] in REGIONES_ORDER:
        data['regiones'].append({
            'r': str(row[0]),
            'u25': safe_int(row[1]),
            'u26': safe_int(row[2]),
        })
data['regiones'].sort(key=lambda x: REGIONES_ORDER.index(x['r']) if x['r'] in REGIONES_ORDER else 99)

# Categorías por región 2026 (filas 65-70 del Dashboard)
data['cats_reg'] = {}
cat_rows_2026 = {}
for row in rows_dash[63:72]:
    if row[0] and row[0] not in ('Categoría \\ Región', 'Total', None):
        cat = str(row[0])
        cat_rows_2026[cat] = {
            'BAJIO-NORTE 2': safe_int(row[1]),
            'CENTRO':        safe_int(row[2]),
            'NOROESTE':      safe_int(row[3]),
            'NORTE 1':       safe_int(row[4]),
            'PACIFICO':      safe_int(row[5]),
            'SUR PENINSULA': safe_int(row[6]),
        }

# ─────────────────────────────────────────────────────────────────────────────
# 2. CATEGORÍAS — totales 2025 vs 2026 desde 2.Base
# ─────────────────────────────────────────────────────────────────────────────
print("Procesando 2.Base (puede tardar ~10 seg)...")
ws_base = wb['2.Base']
cat_year = defaultdict(lambda: {2025: 0, 2026: 0})
reg_cat_year = defaultdict(lambda: defaultdict(lambda: {2025: 0, 2026: 0}))
cat_month_2026 = defaultdict(lambda: defaultdict(int))  # cat -> mes -> uds

MES = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec']

for i, r in enumerate(ws_base.iter_rows(min_row=4, values_only=True)):
    if i > 300000: break
    if not r[7] or not r[9] or not r[10] or not r[0] or not r[8]:
        continue
    try:
        units  = safe_int(r[7])
        year   = safe_int(r[9])
        cat    = str(r[10]).strip()
        region = str(r[0]).strip()
        mes    = str(r[8]).strip()
    except Exception:
        continue
    if not cat or year not in (2025, 2026):
        continue
    cat_year[cat][year] += units
    reg_cat_year[region][cat][year] += units
    if year == 2026 and mes in MES[:6]:
        cat_month_2026[cat][mes] += units

data['cats'] = [
    {'c': c, 'u25': v[2025], 'u26': v[2026]}
    for c, v in sorted(cat_year.items(), key=lambda x: -x[1][2026])
]

# cats_reg completo (2025 + 2026) por región
for reg in REGIONES_ORDER:
    reg_cats = []
    for cat in cat_year:
        u25 = reg_cat_year[reg][cat][2025]
        u26 = reg_cat_year[reg][cat][2026]
        reg_cats.append({'c': cat, 'u25': u25, 'u26': u26})
    data['cats_reg'][reg] = sorted(reg_cats, key=lambda x: -x['u26'])

# Ventas promedio mensual Jan-Jun 2026 por categoría (para rotación)
data['cat_avg_monthly_2026'] = {
    cat: round(sum(months.values()) / 6, 1)
    for cat, months in cat_month_2026.items()
}

# ─────────────────────────────────────────────────────────────────────────────
# 3. OH INVENTARIO
# ─────────────────────────────────────────────────────────────────────────────
print("Procesando OH detalle...")
ws_oh = wb['OH detalle']
OH_CATS = ['Cables','Cases iPhone','Charger','Liquid','Micas','Accesories']

reg_cat_oh = defaultdict(lambda: defaultdict(int))
pdv_oh = defaultdict(lambda: {
    'nombre':'','region':'','gerente':'','clave':'',
    'Cables':0,'Cases iPhone':0,'Charger':0,'Liquid':0,'Micas':0,'Accesories':0,'Total':0
})
modelo_oh = defaultdict(lambda: {'descripcion':'','cat':'','qty':0})

for r in ws_oh.iter_rows(min_row=4, values_only=True):
    if not r[0]: continue
    tipo  = str(r[11]) if r[11] else ''
    if tipo != 'ACCESORIO': continue
    region = str(r[3]) if r[3] else ''
    clave  = str(r[1]) if r[1] else ''
    nombre = str(r[0]) if r[0] else ''
    gerente= str(r[2]) if r[2] else ''
    desc   = str(r[6]) if r[6] else ''
    cat    = str(r[7]) if r[7] else ''
    sku    = str(r[4]) if r[4] else ''
    qty    = safe_int(r[10])
    if qty <= 0: continue
    reg_cat_oh[region][cat]     += qty
    reg_cat_oh[region]['Total'] += qty
    pdv_oh[clave]['nombre']  = nombre
    pdv_oh[clave]['region']  = region
    pdv_oh[clave]['gerente'] = gerente
    pdv_oh[clave]['clave']   = clave
    if cat in OH_CATS:
        pdv_oh[clave][cat] += qty
    pdv_oh[clave]['Total'] += qty
    if sku:
        modelo_oh[sku]['descripcion'] = desc
        modelo_oh[sku]['cat']         = cat
        modelo_oh[sku]['qty']        += qty

# OH_CATS totals
data['oh_cats'] = [
    {'c': c, 'u': sum(reg_cat_oh[r].get(c, 0) for r in REGIONES_ORDER)}
    for c in OH_CATS
]
data['oh_total'] = sum(x['u'] for x in data['oh_cats'])

# OH por región
data['oh_reg'] = []
for reg in REGIONES_ORDER:
    d = reg_cat_oh[reg]
    data['oh_reg'].append({
        'r': reg,
        'total':          d.get('Total', 0),
        'Cables':         d.get('Cables', 0),
        'Cases iPhone':   d.get('Cases iPhone', 0),
        'Charger':        d.get('Charger', 0),
        'Liquid':         d.get('Liquid', 0),
        'Micas':          d.get('Micas', 0),
        'Accesories':     d.get('Accesories', 0),
    })

# Top modelos
data['oh_modelos'] = sorted(
    [{'d': v['descripcion'], 'c': v['cat'], 'u': v['qty']} for v in modelo_oh.values()],
    key=lambda x: -x['u']
)[:20]

# Top PDV globales
data['oh_top_pdv'] = sorted(
    list(pdv_oh.values()),
    key=lambda x: -x['Total']
)[:20]

# OH por PDV agrupado por región (todas las tiendas)
oh_pdv_by_reg = defaultdict(list)
for clave, p in pdv_oh.items():
    oh_pdv_by_reg[p['region']].append(p)
for reg in oh_pdv_by_reg:
    oh_pdv_by_reg[reg].sort(key=lambda x: -x['Total'])
data['oh_pdv_reg'] = {reg: oh_pdv_by_reg[reg] for reg in REGIONES_ORDER if reg in oh_pdv_by_reg}

# ─────────────────────────────────────────────────────────────────────────────
# 4. CUOTA JULIO — tiendas
# ─────────────────────────────────────────────────────────────────────────────
print("Procesando Cuota Jul...")
ws_cuota = wb['Cuota Jul']
rows_cuota = list(ws_cuota.iter_rows(values_only=True))

# Gerente/Director de Proyección Tienda
ws_proy = wb['Proyección Tienda']
pdv_gerente = {}
pdv_director = {}
for r in list(ws_proy.iter_rows(min_row=4, values_only=True)):
    if not r[3]: continue
    pdv_gerente[str(r[3])]  = str(r[2]) if r[2] else ''
    pdv_director[str(r[3])] = str(r[1]) if r[1] else ''

cuota_stores = []
for r in rows_cuota[1:]:
    if not r[0] or r[0] == 'REGION_PRIME': continue
    clave = str(r[2]) if r[2] else ''
    cuota_stores.append({
        'region':    str(r[0]),
        'subregion': str(r[1]) if r[1] else '',
        'clave':     clave,
        'nombre':    str(r[3]) if r[3] else '',
        'cuota':     safe_int(r[4]),
        'venta':     safe_int(r[5]),
        'alcance':   safe_float(r[6]),
        'oh':        safe_int(r[7]),
        'resurtido': safe_int(r[8]),
        'faltante':  safe_int(r[9]),
        'riesgo':    str(r[10]) if r[10] else '',
        'gerente':   pdv_gerente.get(clave, ''),
        'director':  pdv_director.get(clave, ''),
    })
data['cuota_stores'] = cuota_stores

# ─────────────────────────────────────────────────────────────────────────────
# 5. ATTACH RATE (1.AR)
# ─────────────────────────────────────────────────────────────────────────────
print("Procesando AR...")
ws_ar = wb['1.AR']
ar_rows = list(ws_ar.iter_rows(min_row=4, values_only=True))
ar_stores = []
for r in ar_rows:
    if not r[0] or str(r[0]).startswith('TOTAL'): continue
    ar_stores.append({
        'region':      str(r[0]),
        'director':    str(r[1]) if r[1] else '',
        'gerente':     str(r[2]) if r[2] else '',
        'clave':       str(r[3]) if r[3] else '',
        'nombre':      str(r[4]) if r[4] else '',
        'alpha':       safe_int(r[5]),
        'total_acc':   safe_int(r[6]),
        'pct_alpha':   safe_float(r[7]),
        'equipo':      safe_int(r[8]),
        'ar':          safe_float(r[9]),
        'alpha_proy':  safe_float(r[10]),
        'equipo_proy': safe_float(r[11]),
        'ar_proy':     safe_float(r[12]),
    })
data['ar_stores'] = ar_stores

# ─────────────────────────────────────────────────────────────────────────────
# 6. CUOTA LC (Liquid Glass + Cases)
# ─────────────────────────────────────────────────────────────────────────────
print("Procesando Cuota LC...")
ws_lc = wb['Cuota LG-Cases Jul']
rows_lc = list(ws_lc.iter_rows(values_only=True))

# Cuotas globales (filas 3-4, índice 3-4)
data['lc_cuota_liquid'] = safe_int(rows_lc[3][3])
data['lc_cuota_cases']  = safe_int(rows_lc[4][3])

# Resumen por región (filas 8-13)
lc_reg = []
for row in rows_lc[7:15]:
    if not row[0] or row[0] == 'Región' or row[0] == 'TOTAL': continue
    lc_reg.append({
        'r':           str(row[0]),
        'lg_venta':    safe_int(row[3]),
        'lg_cuota':    safe_float(row[5]),
        'lg_alcance':  safe_float(row[6]),
        'cases_venta': safe_int(row[7]),
        'cases_cuota': safe_float(row[9]),
        'cases_alcance': safe_float(row[10]),
    })
data['lc_reg'] = lc_reg

# Detalle por tienda (fila 18 en adelante)
lc_stores = []
for row in rows_lc[17:]:
    if not row[0] or row[0] == 'Región': continue
    # Necesitamos OH de Cases y Liquid por tienda (del OH_PDV_DATA)
    clave = str(row[1]) if row[1] else ''
    lc_stores.append({
        'region':        str(row[0]),
        'clave':         clave,
        'nombre':        str(row[2]) if row[2] else '',
        'gerente':       pdv_gerente.get(clave, ''),
        'lg_venta':      safe_int(row[3]),
        'lg_cuota':      safe_float(row[5]),
        'lg_alcance':    safe_float(row[6]),
        'cases_venta':   safe_int(row[7]),
        'cases_cuota':   safe_float(row[9]),
        'cases_alcance': safe_float(row[10]),
        'oh_cases':      pdv_oh.get(clave, {}).get('Cases iPhone', 0),
        'oh_liquid':     pdv_oh.get(clave, {}).get('Liquid', 0),
    })
data['lc_stores'] = lc_stores

# ─────────────────────────────────────────────────────────────────────────────
# 7. FECHA DEL REPORTE
# ─────────────────────────────────────────────────────────────────────────────
data['fecha'] = datetime.date.today().strftime('%d %b %Y')

# ─────────────────────────────────────────────────────────────────────────────
# OUTPUT — genera data.js (funciona con file:// y con GitHub Pages)
# ─────────────────────────────────────────────────────────────────────────────
json_str = json.dumps(data, ensure_ascii=False, separators=(',', ':'))

# data.js: asigna el objeto a una variable global para cargarlo como <script>
out_js = Path(__file__).parent / 'data.js'
with open(out_js, 'w', encoding='utf-8') as f:
    f.write(f'window.DASHBOARD_DATA={json_str};')

# data.json: también lo guardamos para compatibilidad
out_json = Path(__file__).parent / 'data.json'
with open(out_json, 'w', encoding='utf-8') as f:
    json.dump(data, f, ensure_ascii=False, separators=(',', ':'))

size_kb = out_js.stat().st_size / 1024
print(f"\n✅ data.js  generado en {out_js}  ({size_kb:.1f} KB)")
print(f"✅ data.json generado en {out_json}")
print(f"   KPIs: {data['kpis']}")
print(f"   Tiendas cuota: {len(data['cuota_stores'])}")
print(f"   Tiendas AR:    {len(data['ar_stores'])}")
print(f"   OH total:      {data['oh_total']:,} uds")

